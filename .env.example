# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=webrtc
DB_USER=webrtc
DB_PASSWORD=webrtcpass

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=8h

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# Set to the URL where the frontend is served (used for CORS)
FRONTEND_ORIGIN=http://localhost
# Set to "true" when serving over HTTPS
COOKIE_SECURE=false

# ── Client port (host-side) ───────────────────────────────────────────────────
CLIENT_PORT=80
