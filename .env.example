# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=webrtc
DB_USER=webrtc
DB_PASSWORD=                        # required — choose a strong password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=                         # required
JWT_EXPIRES_IN=8h

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# URL the browser uses to reach the frontend (must match for CORS + cookies)
FRONTEND_ORIGIN=https://localhost
# Set true when serving over HTTPS (required for httpOnly Secure cookies)
COOKIE_SECURE=true

# ── Client (Nginx) ────────────────────────────────────────────────────────────
CLIENT_HTTPS_PORT=443

# ── Asterisk ──────────────────────────────────────────────────────────────────
# LAN IP of the machine running Docker — used for SIP/RTP NAT settings
# Example: 192.168.1.50
ASTERISK_EXTERNAL_IP=127.0.0.1
ASTERISK_UDP_PORT=5060
ASTERISK_WS_PORT=8088
ASTERISK_WSS_PORT=8089

# SIP passwords for the three test extensions (1001, 1002, 1003)
SIP_PASSWORD_1001=WebRTC1001!
SIP_PASSWORD_1002=WebRTC1002!
SIP_PASSWORD_1003=WebRTC1003!
