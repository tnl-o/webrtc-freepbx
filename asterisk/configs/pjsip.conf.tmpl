;==============================================================================
; Asterisk PJSIP configuration — WebRTC LAN mode
; Generated from pjsip.conf.tmpl by entrypoint.sh via envsubst.
; Variables: ${ASTERISK_EXTERNAL_IP}, ${SIP_PASSWORD_100x}
;==============================================================================

[global]
type = global
debug = no

;==============================================================================
; Transports
; For HTTPS-served pages, browsers enforce mixed-content rules:
;   HTTPS page  → must use wss:// for SIP WebSocket
;   HTTP page   → may use ws:// for SIP WebSocket
;
; We expose BOTH, but all three test extensions use transport-wss.
; Use transport-ws only if you serve the frontend over plain HTTP.
;==============================================================================

[transport-udp]
type = transport
protocol = udp
bind = 0.0.0.0:5060
external_media_address = ${ASTERISK_EXTERNAL_IP}
external_signaling_address = ${ASTERISK_EXTERNAL_IP}
local_net = 10.0.0.0/8
local_net = 172.16.0.0/12
local_net = 192.168.0.0/16

[transport-ws]
type = transport
protocol = ws
bind = 0.0.0.0:8088
external_media_address = ${ASTERISK_EXTERNAL_IP}
external_signaling_address = ${ASTERISK_EXTERNAL_IP}
local_net = 10.0.0.0/8
local_net = 172.16.0.0/12
local_net = 192.168.0.0/16

[transport-wss]
type = transport
protocol = wss
bind = 0.0.0.0:8089
cert_file = /etc/asterisk/keys/asterisk.pem
priv_key_file = /etc/asterisk/keys/asterisk.pem
external_media_address = ${ASTERISK_EXTERNAL_IP}
external_signaling_address = ${ASTERISK_EXTERNAL_IP}
local_net = 10.0.0.0/8
local_net = 172.16.0.0/12
local_net = 192.168.0.0/16

;==============================================================================
; Endpoint template (inherited by all extensions)
; webrtc=yes expands to: use_avpf, media_encryption=dtls, dtls_verify=fingerprint,
;   dtls_setup=actpass, ice_support=yes, rtcp_mux=yes, use_received_transport=yes
;==============================================================================

[webrtc_endpoint](!)
type = endpoint
; ── Fix: context matches extensions.conf [from-webrtc] section ──────────────
context = from-webrtc
allow = !all,ulaw,alaw,g722,opus
webrtc = yes
dtls_cert_file = /etc/asterisk/keys/asterisk.pem
dtls_private_key = /etc/asterisk/keys/asterisk.pem
dtls_setup = actpass
dtls_verify = no
timers = no
direct_media = no
dtmf_mode = rfc4733
force_rport = yes
rewrite_contact = yes

[webrtc_auth](!)
type = auth
auth_type = userpass

[webrtc_aor](!)
type = aor
max_contacts = 5
qualify_frequency = 30
remove_existing = yes

;==============================================================================
; Extension 1001 — WSS (required for HTTPS frontend)
;==============================================================================

[1001](webrtc_endpoint)
transport = transport-wss
auth = 1001_auth
aors = 1001_aor
callerid = "Extension 1001" <1001>

[1001_auth](webrtc_auth)
username = 1001
password = ${SIP_PASSWORD_1001:-WebRTC1001!}

[1001_aor](webrtc_aor)

;==============================================================================
; Extension 1002 — WSS
;==============================================================================

[1002](webrtc_endpoint)
transport = transport-wss
auth = 1002_auth
aors = 1002_aor
callerid = "Extension 1002" <1002>

[1002_auth](webrtc_auth)
username = 1002
password = ${SIP_PASSWORD_1002:-WebRTC1002!}

[1002_aor](webrtc_aor)

;==============================================================================
; Extension 1003 — WSS
; (Previously ws://, changed to wss:// to prevent mixed-content browser errors
;  when the frontend is served over HTTPS)
;==============================================================================

[1003](webrtc_endpoint)
transport = transport-wss
auth = 1003_auth
aors = 1003_aor
callerid = "Extension 1003" <1003>

[1003_auth](webrtc_auth)
username = 1003
password = ${SIP_PASSWORD_1003:-WebRTC1003!}

[1003_aor](webrtc_aor)
